<nav class="nav left">
  <a href="{{#if site.homeUrl}}{{{relativize site.homeUrl}}}{{else}}{{{relativize (startPageUrl site.startPage)}}}{{/if}}">
    <i>home</i>
  </a>
  {{!-- <a>
    <i>code</i>
  </a>
  <a>
    <i>book</i>
  </a> --}}
  <div class="max"></div>
  <button class="circle transparent">
    <i id="mode-icon">brightness_auto</i>
    <script>
      const THEME_STORAGE_KEY = "ui-mode";
      const THEME_MAP = {
        light: "light_mode",
        dark: "dark_mode",
        auto: "brightness_auto",
      };
      const THEME_MODES = ["auto", "light", "dark"];

      const setRootThemeClass = mode => {
        const root = document.documentElement;
        root.classList.remove("light", "dark", "sl-theme-light", "sl-theme-dark");
        root.classList.add(mode);
        root.classList.add("sl-theme-" + mode);
        document.querySelectorAll(`.theme-media.${mode} video`).forEach(v => { v.currentTime = 0; v.play() });
      };

      me().on("click", async () => {
        const current = localStorage.getItem(THEME_STORAGE_KEY) || "auto";
        const next = THEME_MODES[(THEME_MODES.indexOf(current) + 1) % THEME_MODES.length];

        await ui("mode", next);
        localStorage.setItem(THEME_STORAGE_KEY, next);

        const resolved = ui("mode");
        setRootThemeClass(resolved);
        me("#mode-icon").innerText = THEME_MAP[next];
      });

      onloadAdd(_ => {
        const stored = localStorage.getItem(THEME_STORAGE_KEY) || "auto";
        ui("mode", stored);
        const resolved = ui("mode");
        me("#mode-icon").innerText = THEME_MAP[stored];
        setRootThemeClass(resolved);
      })
    </script>
  </button>
</nav>
